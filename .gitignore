# Core: Ignore the entire local_build directory and everything inside it
local_build/
local_build/**

# Build / temp artifacts that could be generated locally
dist/
build/
out/
.tmp/
*.tmp
*.temp

# Editor / IDE junk (VSCode, JetBrains, Vim, etc.)
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node / npm (in case we ever add a build step later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnpm-store/

# Environment / secrets (even though client-side, never commit them)
.env
.env.local
.env.development
.env.production
*.key
*.pem
*.crt
*.p12

# Test / fuzz / payload generation folders (common in pentest tooling)
test/
tests/
fuzz/
payloads/
wordlists-local/
screenshots/
har/
logs/
*.log

# Browser / extension dev junk
.cache/
.web-ext-*
*.crx
*.xpi

# OS-specific
# macOS
.AppleDouble
.LSOverride

# Windows
ehthumbs.db
Desktop.ini

# Linux
*~

# =============================================
# Security-hardened extras (because we are pentesters)
# =============================================
# Never leak any credential material, even in comments or docs
*.secret
*.token
*.creds
*.password

# Local pentest session files
*.session
*.har
*.pcapng
*.pcap

# AI / LLM scratch files that might contain sensitive test cases
*.prompt
*.context
*.llm

# Force-include the public static assets that GitHub Pages serves
!index.html
!assets/
!assets/**
!css/
!css/**
!js/
!js/**
!images/
!images/**
!docs/
!docs/**

